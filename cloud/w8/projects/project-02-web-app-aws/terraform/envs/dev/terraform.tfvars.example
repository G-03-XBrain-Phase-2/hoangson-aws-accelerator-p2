aws_region   = "ap-southeast-1"
project_name = "demo-web-app"
owner        = "nguyen-hoang-son"
environment  = "dev"

vpc_cidr             = "10.50.0.0/16"
public_subnet_cidrs  = ["10.50.1.0/24", "10.50.2.0/24"]
private_subnet_cidrs = ["10.50.11.0/24", "10.50.12.0/24"]

# For learning, 0.0.0.0/0 makes the website easy to test.
# For tighter access, replace with "YOUR_PUBLIC_IP/32".
web_ingress_cidr = "0.0.0.0/0"

instance_type    = "t3.micro"
root_volume_size = 30

db_instance_class           = "db.t3.micro"
db_allocated_storage        = 20
db_name                     = "appdb"
db_username                 = "appadmin"
db_backup_retention_period  = 1
db_skip_final_snapshot      = true
db_deletion_protection      = false
assets_bucket_name          = null
