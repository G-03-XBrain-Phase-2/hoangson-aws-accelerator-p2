# ArgoCD App: signature admission policy.
# Copy this file to image-policy.yaml only after the app image is signed.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: image-policy
  namespace: argocd
  annotations:
    argocd.argoproj.io/sync-wave: "10"
spec:
  project: default
  source:
    repoURL: https://github.com/G-03-XBrain-Phase-2/hoangson-aws-accelerator-p2.git
    path: cloud/w10/project-02-secure-operate-gitops-lab/image-policy
    targetRevision: main
  destination:
    server: https://kubernetes.default.svc
    namespace: cosign-system
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - ServerSideApply=true



